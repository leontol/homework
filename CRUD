from datetime import datetime
from typing import Optional, List
from enum import Enum
from pydantic import BaseModel, Field, field_validator

# -------------- ENUMS (Перечисления) ----------

class TaskStatusEnum(str, Enum):
    PENDING = "pending"           # Ожидает выполнения (начальное состояние)
    IN_PROGRESS = "in_progress"   # В процессе выполнения
    COMPLETED = "completed"       # Выполнена


class TaskPriorityEnum(str, Enum):
    LOW = "low"                    # Низкий приоритет
    MEDIUM = "medium"              # Средний приоритет (по умолчанию)
    HIGH = "high"                  # Высокий приоритет

# ---------- PYDANTIC МОДЕЛИ ----------

class TaskCreate(BaseModel):                                             # создания новой задачи
    title: str = Field(..., min_length=1, max_length=200)                # название задачи
    description: Optional[str] = Field(None)                             # описание задачи
    status: TaskStatusEnum = Field(default=TaskStatusEnum.PENDING)       # статус задачи
    priority: TaskPriorityEnum = Field(default=TaskPriorityEnum.MEDIUM)  # приоритет задачи

    @field_validator('title')
    @classmethod
    def title_not_empty(cls, v):                                         # проверяет нет ли пробелов
        v = v.strip()
        if not v:
            raise ValueError('Название задачи не может быть пустым')
        return v


class TaskUpdate(BaseModel):                                             # обновление существующей задачи
    title: Optional[str] = Field(None, min_length=1, max_length=200)
    description: Optional[str] = Field(None)
    status: Optional[TaskStatusEnum] = Field(None)
    priority: Optional[TaskPriorityEnum] = Field(None)

    @field_validator('title')
    @classmethod
    def title_not_empty(cls, v):
        if v is not None:
            v = v.strip()
            if not v:
                raise ValueError('Название задачи не может быть пустым')
        return v


class TaskResponse(BaseModel):                                            # ответ API с данными задачи
    id: str
    title: str
    description: Optional[str] = None
    status: TaskStatusEnum
    priority: TaskPriorityEnum
    created_at: datetime
    updated_at: datetime
    completed_at: Optional[datetime] = None

    model_config = {"from_attributes": True}


class TaskReorder(BaseModel):                                            # изменения порядка следования задачи
    task_ids: List[str]

    @field_validator('task_ids')
    @classmethod
    def check_unique(cls, v):
        if len(v) != len(set(v)):
            raise ValueError('ID задач должны быть уникальными')
        return v


class TaskDelete(BaseModel):                                             # удаление задачи
    task_id: str = Field(..., min_length=1, description="ID задачи для удаления")
    confirm: bool = Field(..., description="Подтверждение удаления")

    @field_validator('confirm')
    @classmethod
    def confirm_deletion(cls, v):
        if not v:
            raise ValueError('Для удаления задачи необходимо подтверждение (confirm=True)')
        return v
